{
  "realm": "medbridge",
  "displayName": "MedBridge",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "loginTheme": "medbridge",
  "accountTheme": "keycloak.v2",
  "adminTheme": "keycloak.v2",
  "emailTheme": "keycloak",
  "bruteForceProtected": true,
  "permanentLockout": false,
  "accessTokenLifespan": 300,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionMaxLifespan": 5184000,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard authenticated user",
        "composite": false
      },
      {
        "name": "ADMIN",
        "description": "Platform administrator",
        "composite": false
      }
    ]
  },
  "defaultRoles": [
    "USER"
  ],
  "clients": [
    {
      "clientId": "medbridge-web",
      "name": "MedBridge Web App",
      "description": "SPA frontend \u2014 Authorization Code + PKCE",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ]
    },
    {
      "clientId": "medbridge-service",
      "name": "MedBridge Internal Service",
      "description": "Service-to-service \u2014 Client Credentials",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "medbridge-service-secret"
    }
  ]
}